# Unified Docker Agent Environment Template
# Copy to .env and fill in the values
# Build: docker build -t lancer1977/dockeragent:latest .
# Run: docker stack deploy -c docker-compose.yml docker-agents

# ============================================
# Common Settings
# ============================================
VERSION=latest
DOCKER_REGISTRY=lancer1977
TZ=America/New_York
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ============================================
# GitHub Actions Runner (RUNNER_TYPE=github)
# ============================================
GITHUB_ORG=Polyhydra-Games
GITHUB_TOKEN=
GITHUB_RUNNER_NAME=${HOSTNAME:-github-runner}
GITHUB_RUNNER_LABELS=docker,linux

# ============================================
# Azure DevOps Agent (RUNNER_TYPE=azure)
# ============================================
AZDO_ORG_URL=https://dev.azure.com/PolyhydraGames
AZDO_TOKEN=
AZDO_POOL=Default
AZDO_AGENT_NAME=${HOSTNAME:-azure-runner}

# ============================================
# Godot Agent (RUNNER_TYPE=godot)
# ============================================
GODOT_VERSION=4.2.2
GODOT_PROJECT_PATH=/godot-projects