# DockerAgent Bitwarden-backed environment template
#
# Preferred flow:
#   1) Store config in Bitwarden item:   DockerAgent - Config
#   2) Store secrets in Bitwarden item:  DockerAgent - Secrets
#   3) Unlock bw locally
#   4) Run: ./render-env-from-bitwarden.sh
#   5) Deploy: docker stack deploy -c docker-compose.yml docker-agents
#
# This file is now mostly documentation/defaults.
# Generated runtime values should live in .env.runtime, not here.

# Optional: override generated env file path used by compose
DOCKERAGENT_ENV_FILE=.env.runtime

# Optional: override Bitwarden item ids used by render-env-from-bitwarden.sh
BW_DOCKERAGENT_CONFIG_ITEM_ID=5bae9e62-e9d8-433c-8019-b40b003c93a3
BW_DOCKERAGENT_SECRETS_ITEM_ID=312c2b11-63d8-4055-9b59-b40b003c9a75

# ============================================
# Values stored in Bitwarden: DockerAgent - Config
# ============================================
VERSION=latest
DOCKER_REGISTRY=lancer1977
TZ=America/New_York
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

GITHUB_ORG=Polyhydra-Games
GITHUB_URL=https://github.com/Polyhydra-Games
GITHUB_RUNNER_NAME=github-runner
GITHUB_RUNNER_LABELS=docker,linux

AZDO_ORG_URL=https://dev.azure.com/PolyhydraGames
AZDO_POOL=Default
AZDO_AGENT_NAME=azure-runner

GODOT_VERSION=4.2.2
GODOT_PROJECT_PATH=/godot-projects

# ============================================
# Values stored in Bitwarden: DockerAgent - Secrets
# ============================================
# GITHUB_TOKEN
# AZDO_TOKEN
