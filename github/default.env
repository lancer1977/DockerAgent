# --------------------------------------------------
# GitHub Actions Runner
# --------------------------------------------------
GITHUB_URL=https://github.com/YOUR_ORG/YOUR_REPO
GITHUB_TOKEN=YOUR_GITHUB_PAT

# --------------------------------------------------
# Runner Configuration
# --------------------------------------------------
GITHUB_RUNNER_NAME=github-runner-$(hostname)
GITHUB_RUNNER_POOL=Default

# --------------------------------------------------
# Docker Hub (for build/push)
# --------------------------------------------------
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PAT=your_dockerhub_pat

# --------------------------------------------------
# Optional: GitHub Packages
# --------------------------------------------------
GITHUB_PACKAGES_TOKEN=your_github_packages_token