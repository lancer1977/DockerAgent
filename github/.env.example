# =====================================================
# GitHub Self-Hosted Runner - Environment Configuration
# =====================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run:
#   docker-compose up -d
#
# =====================================================

# --- GitHub URL ---
# Use your personal account OR organization URL
# Personal: https://github.com/your-username
# Org:      https://github.com/your-org
GITHUB_URL=https://github.com/lancer1977

# --- GitHub Token ---
# Generate at: GitHub → Settings → Actions → Runners → "New self-hosted runner"
# OR: GitHub → Settings → Developer settings → Personal access tokens (classic)
# Required scope: repo, admin:org (for org runners), read:packages (for GHCR)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- GitHub Container Registry ---
# Used to pull the runner image from ghcr.io
# Usually same as GITHUB_TOKEN if using a PAT
GHCR_USERNAME=your-github-username
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- GitHub Packages Token ---
# Same as GHCR_TOKEN usually
GITHUB_PACKAGES_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Runner Pool ---
# Group name for runners (appears in GitHub Actions workflow selector)
# Default: "Default"
GITHUB_RUNNER_POOL=Default

# =====================================================
# OPTIONAL: Additional Configuration
# =====================================================

# Timezone (default: US/Eastern)
# TZ=US/Eastern

# User/Group IDs for file permissions (default: 1000)
# GUID=1000
# PUID=1000

# =====================================================
# To generate a new runner token:
# =====================================================
# 1. Go to: https://github.com/settings/actions/runners
# 2. Click "New self-hosted runner"
# 3. Select your OS (Linux) and architecture (x64)
# 4. Copy the token from the "Configure" step
#    (it looks like: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx)
# =====================================================