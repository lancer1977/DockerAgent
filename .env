# Docker Agent Environment Template
# Copy to .env and fill in the values

# ============================================
# GitHub Actions Runner
# ============================================
GITHUB_RUNNER_VERSION=latest
GITHUB_ORG=Polyhydra-Games
GITHUB_TOKEN=
GITHUB_RUNNER_NAME=github-runner
GITHUB_RUNNER_LABELS=docker,linux

# ============================================
# Azure DevOps Agent
# ============================================
AZDO_ORG_URL=https://dev.azure.com/PolyhydraGames
AZDO_TOKEN=
AZDO_POOL=Default
AZDO_AGENT_NAME=azure-runner

# ============================================
# Godot Agent
# ============================================
GODOT_VERSION=4.2.2
GODOT_PROJECT_PATH=

# ============================================
# Common Settings
# ============================================
TZ=America/New_York
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1